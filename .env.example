# Token de tu bot proporcionado por @BotFather en Telegram
TELEGRAM_BOT_TOKEN=tu_telegram_bot_token_aqui

# ID numérico del administrador o grupo donde se enviarán las alertas de Telegram
TELEGRAM_ADMIN_CHAT_ID=123456789

# URL del Webhook de Discord para enviar notificaciones al canal deseado
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/tu_webhook_id/tu_webhook_token

# Token secreto para la API interna de Valkiria
INTERNAL_API_TOKEN=tu_token_secreto_aqui

# (Opcional) Nombre del servidor para identificarlo en las alertas (ej. TIQUEO, PROD)
SERVER_NAME=TIQUEO

